# Port service agent (local dev only)
PORT=8787

# Public URL — set to deployed URL on Vercel, e.g. https://your-agent.vercel.app
# Falls back to http://localhost:$PORT in dev
AGENT_PUBLIC_URL=

# Venice AI (Fase 3) — https://docs.venice.ai
VENICE_API_KEY=
VENICE_BASE_URL=https://api.venice.ai/api/v1

# 1Shot API relayer (Fase 2) — https://1shotapi.com/docs
ONESHOT_API_KEY=
ONESHOT_WEBHOOK_SECRET=
# JSON-RPC relayer URL — required for 1Shot relay
# ONESHOT_RELAYER_URL=

